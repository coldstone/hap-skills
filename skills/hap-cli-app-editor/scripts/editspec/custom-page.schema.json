{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "custom-page ops",
  "description": "Deep schema for op.type starting with 'custom-page.' — page create/update/delete (page-level metadata). Component edits are 'component.*' ops in component.schema.json.",
  "oneOf": [
    { "$ref": "#/$defs/create" },
    { "$ref": "#/$defs/update" },
    { "$ref": "#/$defs/delete" }
  ],
  "$defs": {
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "custom-page.create" },
        "label": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "description": "Section name or id." },
        "icon": { "type": "string" },
        "remark": { "type": "string" }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "page"],
      "properties": {
        "type": { "const": "custom-page.update" },
        "label": { "type": "string" },
        "page": { "type": "string", "minLength": 1, "description": "Page name or id." },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "page", "confirm"],
      "properties": {
        "type": { "const": "custom-page.delete" },
        "label": { "type": "string" },
        "page": { "type": "string", "minLength": 1 },
        "permanent": { "type": "boolean" },
        "confirm": { "type": "boolean", "const": true }
      }
    }
  }
}
