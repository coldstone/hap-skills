{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "role ops",
  "description": "Deep schema for op.type starting with 'role.'. Covers role create/update/delete and member add/remove.",
  "oneOf": [
    { "$ref": "#/$defs/create" },
    { "$ref": "#/$defs/update" },
    { "$ref": "#/$defs/delete" },
    { "$ref": "#/$defs/add_member" },
    { "$ref": "#/$defs/remove_member" }
  ],
  "$defs": {
    "members": {
      "type": "object",
      "description": "Member selectors. At least one list is required.",
      "properties": {
        "user_ids": { "type": "array", "items": { "type": "string" } },
        "department_ids": { "type": "array", "items": { "type": "string" } },
        "department_tree_ids": { "type": "array", "items": { "type": "string" } },
        "job_ids": { "type": "array", "items": { "type": "string" } },
        "org_role_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "role.create" },
        "label": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "permission_scope": {
          "type": "string",
          "description": "80=view+edit+delete all; 60=view all/edit own; 30=joined only; 20=view-only; 0=per-item. Default 20. Scope 0 REQUIRES non-empty worksheet_permissions."
        },
        "hide_app_for_members": { "type": "boolean" },
        "global_permissions": { "type": "object" },
        "worksheet_permissions": { "type": "array" },
        "page_permissions": { "type": "array" }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role"],
      "properties": {
        "type": { "const": "role.update" },
        "label": { "type": "string" },
        "role": { "type": "string", "minLength": 1, "description": "Role name or id." },
        "rename": { "type": "string", "description": "New role name." },
        "permissions": { "type": "object", "description": "Permissions JSON to set." },
        "permission_way": { "type": "integer", "description": "0=custom,10=readonly,50=member,100=admin." }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role", "confirm"],
      "properties": {
        "type": { "const": "role.delete" },
        "label": { "type": "string" },
        "role": { "type": "string", "minLength": 1 },
        "confirm": { "type": "boolean", "const": true }
      }
    },
    "add_member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role", "members"],
      "properties": {
        "type": { "const": "role.add_member" },
        "label": { "type": "string" },
        "role": { "type": "string", "minLength": 1 },
        "members": { "$ref": "#/$defs/members" }
      }
    },
    "remove_member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role", "members"],
      "properties": {
        "type": { "const": "role.remove_member" },
        "label": { "type": "string" },
        "role": { "type": "string", "minLength": 1 },
        "members": { "$ref": "#/$defs/members" }
      }
    }
  }
}
