{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "view ops",
  "description": "Deep schema for op.type starting with 'view.'. Update is a partial edit driven by edit_attrs (only the listed attributes change).",
  "oneOf": [
    { "$ref": "#/$defs/create" },
    { "$ref": "#/$defs/update" },
    { "$ref": "#/$defs/delete" }
  ],
  "$defs": {
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "worksheet", "name"],
      "properties": {
        "type": { "const": "view.create" },
        "label": { "type": "string" },
        "worksheet": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "view_type": {
          "type": "string",
          "description": "sheet | board | gallery | calendar | gantt | structure | detail | map (or the integer as a string)."
        },
        "config": { "type": "object", "description": "Extra view config (viewControl, coverCid, advancedSetting, filters, ...)." }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "worksheet", "view", "edit_attrs"],
      "properties": {
        "type": { "const": "view.update" },
        "label": { "type": "string" },
        "worksheet": { "type": "string", "minLength": 1 },
        "view": { "type": "string", "minLength": 1, "description": "Target view: name or id." },
        "set": { "type": "object", "description": "Attribute values to write (e.g. {\"name\": \"...\"})." },
        "name": { "type": "string", "description": "Rename shortcut; implies 'name' in edit_attrs." },
        "edit_attrs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Top-level view attributes being changed; only these are updated."
        },
        "edit_ad_keys": {
          "type": "array",
          "items": { "type": "string" },
          "description": "advancedSetting sub-keys to narrow an advancedSetting edit."
        }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "worksheet", "view", "confirm"],
      "properties": {
        "type": { "const": "view.delete" },
        "label": { "type": "string" },
        "worksheet": { "type": "string", "minLength": 1 },
        "view": { "type": "string", "minLength": 1 },
        "confirm": { "type": "boolean", "const": true }
      }
    }
  }
}
