{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "chatbot ops",
  "description": "Deep schema for op.type starting with 'chatbot.' — AI assistant create/update/delete.",
  "oneOf": [
    { "$ref": "#/$defs/create" },
    { "$ref": "#/$defs/update" },
    { "$ref": "#/$defs/delete" }
  ],
  "$defs": {
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "chatbot.create" },
        "label": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "description": "Section name or id." },
        "prompt": { "type": "string", "description": "System prompt." },
        "welcome_text": { "type": "string" },
        "preset_questions": { "type": "array", "items": { "type": "string" } },
        "remark": { "type": "string" }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "chatbot"],
      "properties": {
        "type": { "const": "chatbot.update" },
        "label": { "type": "string" },
        "chatbot": { "type": "string", "minLength": 1, "description": "Assistant name or id." },
        "name": { "type": "string" },
        "welcome_text": { "type": "string" },
        "preset_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "chatbot", "confirm"],
      "properties": {
        "type": { "const": "chatbot.delete" },
        "label": { "type": "string" },
        "chatbot": { "type": "string", "minLength": 1 },
        "permanent": { "type": "boolean" },
        "confirm": { "type": "boolean", "const": true }
      }
    }
  }
}
