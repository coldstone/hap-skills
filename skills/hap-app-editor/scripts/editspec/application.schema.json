{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "application & section ops",
  "description": "Deep schema for op.type starting with 'app.' (application metadata) and 'section.' (sidebar groups). Whole-app creation is hap-app-creator's job; this edits an existing app.",
  "oneOf": [
    { "$ref": "#/$defs/app_update" },
    { "$ref": "#/$defs/section_add" },
    { "$ref": "#/$defs/section_update" },
    { "$ref": "#/$defs/section_delete" }
  ],
  "$defs": {
    "app_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "app.update" },
        "label": { "type": "string" },
        "name": { "type": "string" },
        "desc": { "type": "string" },
        "icon_color": { "type": "string" },
        "nav_color": { "type": "string" },
        "pc_nav_style": { "type": "integer", "description": "0=classic,1=grouped list,2=...,3=..." }
      }
    },
    "section_add": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "section.add" },
        "label": { "type": "string" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "section_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "section", "name"],
      "properties": {
        "type": { "const": "section.update" },
        "label": { "type": "string" },
        "section": { "type": "string", "minLength": 1, "description": "Section name or id." },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "section_delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "section", "confirm"],
      "properties": {
        "type": { "const": "section.delete" },
        "label": { "type": "string" },
        "section": { "type": "string", "minLength": 1 },
        "confirm": { "type": "boolean", "const": true }
      }
    }
  }
}
