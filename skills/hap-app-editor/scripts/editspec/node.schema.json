{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workflow node ops",
  "description": "Deep schema for op.type starting with 'node.' — workflow node ops: append a node after another (the backend rewires connections), update an existing node's full config in place, rename, delete. Mid-branch insertion / complex topology rewiring is out of scope (use hap-app-creator or a recorded payload).",
  "oneOf": [
    { "$ref": "#/$defs/add" },
    { "$ref": "#/$defs/update" },
    { "$ref": "#/$defs/rename" },
    { "$ref": "#/$defs/delete" }
  ],
  "$defs": {
    "add": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "workflow", "node"],
      "properties": {
        "type": { "const": "node.add" },
        "label": { "type": "string" },
        "workflow": { "type": "string", "minLength": 1, "description": "Workflow name or id." },
        "node": {
          "type": "object",
          "required": ["name", "node_type"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "node_type": { "type": "integer", "description": "Node type id (e.g. 13=manual/approval-detail, see 'workflow node types')." },
            "after": { "type": "string", "description": "Node name/id this is inserted after; defaults to the start node." },
            "action_id": { "type": "string", "description": "Action id for data nodes (1=AddRecord, 2=EditRecord, ...)." },
            "worksheet": { "type": "string", "description": "Target worksheet (name/id) for data-action/search nodes." },
            "app_type": { "type": "integer" }
          }
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "workflow", "node", "config"],
      "properties": {
        "type": { "const": "node.update" },
        "label": { "type": "string" },
        "workflow": { "type": "string", "minLength": 1, "description": "Workflow name or id." },
        "node": { "type": "string", "minLength": 1, "description": "Target node name or id (the node id is kept; wiring/position survive)." },
        "config": { "type": "object", "description": "Full wire config for the node, in the shape 'workflow node get' returns. Read current with 'node get', fix the broken bits, pass it back here." },
        "node_type": { "type": "integer", "description": "Node type enum for --type (0=Start,1=Branch,4=Approval,5=CC,6=Action,7=Search,13=GetMore,27=Notice,...). Optional; defaults to the node's live typeId." },
        "name": { "type": "string", "minLength": 1, "description": "Optional new node name." }
      }
    },
    "rename": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "workflow", "node", "name"],
      "properties": {
        "type": { "const": "node.rename" },
        "label": { "type": "string" },
        "workflow": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1, "description": "Target node name or id." },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "workflow", "node", "confirm"],
      "properties": {
        "type": { "const": "node.delete" },
        "label": { "type": "string" },
        "workflow": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1 },
        "confirm": { "type": "boolean", "const": true }
      }
    }
  }
}
